<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NeoAuth - Panel de Control</title>
    
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="/css/bootstrap-icons.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/custom.css">
    
    <style>
        :root {
            --primary: #0f172a;
            --secondary: #1e293b;
            --tertiary: #334155;
            --accent: #3b82f6;
            --accent-light: #60a5fa;
            --accent-dark: #2563eb;
            --success: #22c55e;
            --warning: #f59e0b;
            --danger: #ef4444;
            --text-primary: #f8fafc;
            --text-secondary: #cbd5e1;
            --border: #475569;
            --shadow: rgba(0, 0, 0, 0.4);
        }
        
        * {
            scrollbar-width: thin;
            scrollbar-color: var(--accent) var(--secondary);
        }
        
        *::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        
        *::-webkit-scrollbar-track {
            background: var(--secondary);
        }
        
        *::-webkit-scrollbar-thumb {
            background: var(--accent);
            border-radius: 4px;
        }
        
        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
            background-attachment: fixed;
            color: var(--text-primary);
            min-height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Inter', sans-serif;
            padding-bottom: 2rem;
        }
        
        @media (max-width: 768px) {
            body {
                padding-bottom: 5rem;
            }
        }
        
        .navbar {
            background: rgba(30, 41, 59, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 3px solid var(--accent);
            padding: 0.75rem 0;
            box-shadow: 0 4px 12px var(--shadow);
        }
        
        .navbar-brand {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-primary) !important;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .navbar-brand i {
            color: var(--accent);
            font-size: 1.75rem;
        }
        
        @media (max-width: 576px) {
            .navbar-brand {
                font-size: 1.25rem;
            }
            .navbar-brand i {
                font-size: 1.5rem;
            }
        }
        
        .card {
            background: rgba(30, 41, 59, 0.9);
            border: 1px solid var(--border);
            border-radius: 16px;
            color: var(--text-primary);
            box-shadow: 0 8px 16px var(--shadow);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            overflow: hidden;
            margin-bottom: 1.5rem;
        }
        
        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 24px rgba(59, 130, 246, 0.3);
            border-color: var(--accent);
        }
        
        .card-header {
            background: linear-gradient(135deg, var(--accent-dark) 0%, var(--accent) 100%);
            border-bottom: none;
            color: white;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 1rem 1.25rem;
            font-size: 1.1rem;
        }
        
        .card-header i {
            font-size: 1.5rem;
            opacity: 0.95;
        }
        
        .card-body {
            padding: 1.5rem;
        }
        
        @media (max-width: 768px) {
            .card {
                border-radius: 12px;
                margin-bottom: 1rem;
            }
            .card-header {
                padding: 0.875rem 1rem;
                font-size: 1rem;
            }
            .card-header i {
                font-size: 1.25rem;
            }
            .card-body {
                padding: 1rem;
            }
        }
        
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            border-radius: 24px;
            font-size: 0.875rem;
            font-weight: 600;
            border: 2px solid;
            transition: all 0.3s ease;
        }
        
        .status-badge.connected {
            background: rgba(34, 197, 94, 0.15);
            color: var(--success);
            border-color: var(--success);
        }
        
        .status-badge.disconnected {
            background: rgba(239, 68, 68, 0.15);
            color: var(--danger);
            border-color: var(--danger);
        }
        
        .status-badge i {
            font-size: 0.625rem;
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        .info-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 1.25rem;
            border-bottom: 1px solid rgba(71, 85, 105, 0.5);
            gap: 1rem;
            transition: background 0.2s ease;
        }
        
        .info-row:hover {
            background: rgba(51, 65, 85, 0.3);
        }
        
        .info-row:last-child {
            border-bottom: none;
        }
        
        .info-label {
            color: var(--text-secondary);
            font-weight: 500;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .info-value {
            color: var(--text-primary);
            font-family: 'Courier New', monospace;
            font-weight: 600;
            font-size: 0.9rem;
            text-align: right;
        }
        
        @media (max-width: 576px) {
            .info-row {
                padding: 0.875rem 1rem;
                flex-direction: column;
                align-items: flex-start;
                gap: 0.5rem;
            }
            .info-value {
                text-align: left;
                word-break: break-all;
            }
        }
        
        .btn {
            font-weight: 600;
            border-radius: 10px;
            padding: 0.75rem 1.5rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            border: none;
            position: relative;
            overflow: hidden;
        }
        
        .btn::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.2);
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }
        
        .btn:hover::before {
            width: 300px;
            height: 300px;
        }
        
        .btn i {
            font-size: 1.1rem;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, var(--accent-dark) 0%, var(--accent) 100%);
            color: white;
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(59, 130, 246, 0.4);
            color: white;
        }
        
        .btn-success {
            background: linear-gradient(135deg, #16a34a 0%, var(--success) 100%);
            color: white;
            box-shadow: 0 4px 12px rgba(34, 197, 94, 0.3);
        }
        
        .btn-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(34, 197, 94, 0.4);
            color: white;
        }
        
        .btn-danger {
            background: linear-gradient(135deg, #dc2626 0%, var(--danger) 100%);
            color: white;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
        }
        
        .btn-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(239, 68, 68, 0.4);
            color: white;
        }
        
        .btn-outline-secondary {
            color: var(--accent);
            border: 2px solid var(--accent);
            background: transparent;
        }
        
        .btn-outline-secondary:hover {
            background: var(--accent);
            color: white;
            transform: translateY(-2px);
        }
        
        .btn-sm {
            padding: 0.5rem 1rem;
            font-size: 0.875rem;
        }
        
        .btn-sm i {
            font-size: 1rem;
        }
        
        @media (max-width: 576px) {
            .btn {
                padding: 0.625rem 1.25rem;
                font-size: 0.9rem;
            }
            .btn i {
                font-size: 1rem;
            }
        }
        
        .form-control, .form-select {
            background: rgba(51, 65, 85, 0.5);
            border: 2px solid var(--border);
            color: var(--text-primary);
            border-radius: 10px;
            padding: 0.75rem 1rem;
            transition: all 0.3s ease;
            font-size: 0.95rem;
        }
        
        .form-control:focus, .form-select:focus {
            background: rgba(51, 65, 85, 0.8);
            border-color: var(--accent);
            color: var(--text-primary);
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
            transform: translateY(-1px);
        }
        
        .form-control::placeholder {
            color: var(--text-secondary);
            opacity: 0.7;
        }
        
        .form-label {
            color: var(--text-secondary);
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 0.5rem;
        }
        
        .network-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 1.25rem;
            background: rgba(51, 65, 85, 0.5);
            margin-bottom: 0.75rem;
            border-radius: 12px;
            border-left: 4px solid var(--accent);
            transition: all 0.3s ease;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
        }
        
        .network-item:hover {
            background: rgba(59, 130, 246, 0.15);
            transform: translateX(4px);
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
        }
        
        .network-info {
            flex-grow: 1;
            min-width: 0;
        }
        
        .network-ssid {
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 0.35rem;
            font-size: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        
        .network-ssid i {
            color: var(--accent);
            font-size: 1.1rem;
        }
        
        .network-meta {
            font-size: 0.85rem;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 0.375rem;
        }
        
        @media (max-width: 576px) {
            .network-item {
                padding: 0.875rem 1rem;
                flex-wrap: wrap;
                gap: 0.75rem;
            }
            .network-ssid {
                font-size: 0.95rem;
            }
            .network-meta {
                font-size: 0.8rem;
            }
        }
        
        .card-item {
            padding: 1rem 1.25rem;
            background: rgba(51, 65, 85, 0.5);
            margin-bottom: 0.75rem;
            border-radius: 12px;
            border-left: 4px solid var(--accent);
            animation: slideIn 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
            transition: all 0.3s ease;
        }
        
        .card-item:hover {
            background: rgba(59, 130, 246, 0.15);
            transform: translateX(4px);
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
        }
        
        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(-20px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }
        
        .card-uid {
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--text-primary);
            font-family: 'Courier New', monospace;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .card-uid::before {
            content: '\F1A5';
            font-family: 'bootstrap-icons';
            color: var(--accent);
            font-size: 1.2rem;
        }
        
        .card-time {
            font-size: 0.85rem;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 0.375rem;
        }
        
        @media (max-width: 576px) {
            .card-item {
                padding: 0.875rem 1rem;
            }
            .card-uid {
                font-size: 0.95rem;
            }
        }
        
        .empty-state {
            text-align: center;
            color: var(--text-secondary);
            padding: 2.5rem 1.5rem;
        }
        
        .empty-state i {
            font-size: 3.5rem;
            margin-bottom: 1rem;
            opacity: 0.4;
            color: var(--accent);
        }
        
        .empty-state p {
            margin-bottom: 0.25rem;
            font-weight: 500;
        }
        
        @media (max-width: 576px) {
            .empty-state {
                padding: 1.5rem 1rem;
            }
            .empty-state i {
                font-size: 2.5rem;
            }
        }
        
        .modal-content {
            background: var(--secondary);
            border: 2px solid var(--border);
            color: var(--text-primary);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 20px 40px var(--shadow);
        }
        
        .modal-header {
            background: linear-gradient(135deg, var(--accent-dark) 0%, var(--accent) 100%);
            border-bottom: none;
            color: white;
            padding: 1.25rem 1.5rem;
        }
        
        .modal-title {
            display: flex;
            align-items: center;
            font-weight: 600;
        }
        
        .modal-header .btn-close {
            filter: invert(1) brightness(2);
            opacity: 0.8;
        }
        
        .modal-header .btn-close:hover {
            opacity: 1;
        }
        
        .modal-body {
            padding: 1.5rem;
        }
        
        .modal-footer {
            border-top: 1px solid rgba(71, 85, 105, 0.5);
            background: rgba(51, 65, 85, 0.3);
            padding: 1rem 1.5rem;
        }
        
        .toast-container {
            position: fixed;
            top: 1rem;
            right: 1rem;
            z-index: 1050;
        }
        
        .toast {
            background: rgba(30, 41, 59, 0.98);
            border: 2px solid var(--border);
            color: var(--text-primary);
            border-radius: 12px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(10px);
        }
        
        .toast-header {
            background: transparent;
            border-bottom: 1px solid rgba(71, 85, 105, 0.5);
            color: var(--text-primary);
            padding: 0.75rem 1rem;
        }
        
        .toast-body {
            padding: 1rem;
        }
        
        .toast.success {
            border-left: 5px solid var(--success);
        }
        
        .toast.error {
            border-left: 5px solid var(--danger);
        }
        
        .toast.warning {
            border-left: 5px solid var(--warning);
        }
        
        .toast.info {
            border-left: 5px solid var(--accent);
        }
        
        .toast-icon {
            font-size: 1.35rem;
            margin-right: 0.5rem;
        }
        
        .toast.success .toast-icon {
            color: var(--success);
        }
        
        .toast.error .toast-icon {
            color: var(--danger);
        }
        
        .toast.warning .toast-icon {
            color: var(--warning);
        }
        
        .toast.info .toast-icon {
            color: var(--accent);
        }
        
        .socket-status {
            position: fixed;
            bottom: 1rem;
            right: 1rem;
            padding: 0.75rem 1.25rem;
            border-radius: 24px;
            font-size: 0.875rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            z-index: 1040;
            box-shadow: 0 4px 12px var(--shadow);
            border: 2px solid;
            backdrop-filter: blur(10px);
        }
        
        .socket-status.connected {
            background: rgba(34, 197, 94, 0.2);
            color: var(--success);
            border-color: var(--success);
        }
        
        .socket-status.disconnected {
            background: rgba(239, 68, 68, 0.2);
            color: var(--danger);
            border-color: var(--danger);
        }
        
        .socket-status i {
            font-size: 0.625rem;
        }
        
        @media (max-width: 576px) {
            .socket-status {
                bottom: auto;
                top: 0.5rem;
                right: 0.5rem;
                padding: 0.5rem 0.875rem;
                font-size: 0.8rem;
                border-radius: 20px;
            }
        }
        
        /* Mejoras adicionales de responsive */
        .container-lg {
            padding-left: 1rem;
            padding-right: 1rem;
        }
        
        @media (max-width: 768px) {
            .row {
                margin-left: -0.5rem;
                margin-right: -0.5rem;
            }
            .row > * {
                padding-left: 0.5rem;
                padding-right: 0.5rem;
            }
        }
        
        /* Animación de spin para loaders */
        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        
        /* Animación suave para elementos */
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .card {
            animation: fadeIn 0.5s ease;
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container-lg">
            <a class="navbar-brand" href="#">
                <i class="bi bi-key-fill"></i>
                Panel RFID
            </a>
        </div>
    </nav>

    <!-- Indicador de Conexión -->
    <span id="socketStatus" class="socket-status disconnected">
        <i class="bi bi-circle-fill"></i>
        <span class="d-none d-sm-inline">Desconectado</span>
    </span>

    <!-- Contenido Principal -->
    <div class="container-lg py-4">
        <!-- Fila 1: Información del Sistema -->
        <div class="row mb-4 g-3 g-md-4">
            <div class="col-lg-6 col-md-12">
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-cpu"></i>
                        Información del Sistema
                    </div>
                    <div class="card-body p-0">
                        <div class="info-row">
                            <span class="info-label"><i class="bi bi-fingerprint"></i> ID del Sensor:</span>
                            <span class="info-value" id="sensorId">-</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label"><i class="bi bi-code-square"></i> Firmware:</span>
                            <span class="info-value" id="firmware">-</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label"><i class="bi bi-wifi"></i> Estado WiFi:</span>
                            <span id="wifiStatus">
                                <span class="status-badge disconnected">
                                    <i class="bi bi-circle-fill"></i>
                                    Desconectado
                                </span>
                            </span>
                        </div>
                        <div class="info-row" id="wifiSSIDRow" style="display:none;">
                            <span class="info-label"><i class="bi bi-router"></i> Red Conectada:</span>
                            <span class="info-value" id="wifiSSID">-</span>
                        </div>
                        <div class="info-row" id="wifiIPRow" style="display:none;">
                            <span class="info-label"><i class="bi bi-hdd-network"></i> IP WiFi:</span>
                            <span class="info-value" id="wifiIP">-</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label"><i class="bi bi-broadcast"></i> IP del AP:</span>
                            <span class="info-value" id="apIP">-</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label"><i class="bi bi-sliders"></i> Modo Actual:</span>
                            <span class="info-value" id="currentMode">
                                <span class="status-badge" id="modeBadge">
                                    <i class="bi bi-circle-fill"></i>
                                    -
                                </span>
                            </span>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Cambiar Modo de Operación</label>
                            <select class="form-select" id="modeSelect">
                                <option value="standalone">Standalone - Lector independiente</option>
                                <option value="turnstile">Torniquete - Control de acceso</option>
                            </select>
                        </div>
                        <button class="btn btn-success w-100 mb-2" onclick="changeMode()">
                            <i class="bi bi-gear-fill"></i>
                            Cambiar Modo
                        </button>
                        <button class="btn btn-primary w-100" onclick="refreshConfig()">
                            <i class="bi bi-arrow-clockwise"></i>
                            Actualizar Información
                        </button>
                    </div>
                </div>
            </div>

            <!-- WiFi Management -->
            <div class="col-lg-6 col-md-12">
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-wifi"></i>
                        Gestión de WiFi
                    </div>
                    <div class="card-body">
                        <div id="knownNetworksList" style="max-height: 200px; overflow-y: auto; margin-bottom: 1rem;">
                            <div class="empty-state">
                                <i class="bi bi-diagram-3"></i>
                                <p>No hay redes configuradas</p>
                            </div>
                        </div>
                        <div class="d-grid gap-2">
                            <button class="btn btn-success" onclick="showAddWiFiModal()">
                                <i class="bi bi-plus-circle-fill"></i>
                                Agregar Red WiFi
                            </button>
                            <button class="btn btn-primary" onclick="scanNetworks()">
                                <i class="bi bi-search"></i>
                                Escanear Redes
                            </button>
                            <button class="btn btn-outline-secondary" onclick="connectWiFi()">
                                <i class="bi bi-plug-fill"></i>
                                Conectar a Red Conocida
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Fila 2: Control de Torniquete (solo visible en modo torniquete) -->
        <div class="row mb-4 g-3 g-md-4" id="turnstileControlRow" style="display: none;">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-door-closed-fill"></i>
                        Control Manual del Torniquete
                    </div>
                    <div class="card-body">
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle-fill me-2"></i>
                            <strong>Nota:</strong> El torniquete se bloqueará automáticamente después de 5 segundos.
                        </div>
                        <div class="d-grid gap-3">
                            <button class="btn btn-success btn-lg" onclick="unlockTurnstile()">
                                <i class="bi bi-unlock-fill"></i>
                                Desbloquear Torniquete
                            </button>
                            <button class="btn btn-danger btn-lg" onclick="lockTurnstile()">
                                <i class="bi bi-lock-fill"></i>
                                Bloquear Torniquete
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Fila 3: Historial de Tarjetas -->
        <div class="row g-3 g-md-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-credit-card-2-front"></i>
                        Historial de Tarjetas RFID
                    </div>
                    <div class="card-body">
                        <div id="cardList" style="max-height: 400px; overflow-y: auto; margin-bottom: 1rem;">
                            <div class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <p>Esperando tarjetas...</p>
                            </div>
                        </div>
                        <button class="btn btn-danger w-100" onclick="clearHistory()">
                            <i class="bi bi-trash3"></i>
                            Limpiar Historial
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal: Agregar WiFi -->
    <div class="modal fade" id="addWiFiModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-plus-circle me-2"></i>
                        Agregar Red WiFi
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nombre de la Red (SSID)</label>
                        <input type="text" class="form-control" id="newSSID" placeholder="Mi Red WiFi">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Contraseña</label>
                        <input type="password" class="form-control" id="newPassword" placeholder="Dejar vacío si es abierta">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle"></i>
                        Cancelar
                    </button>
                    <button type="button" class="btn btn-success" onclick="addWiFi()">
                        <i class="bi bi-check-circle"></i>
                        Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal: Escanear Redes -->
    <div class="modal fade" id="scanModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-search me-2"></i>
                        Redes WiFi Disponibles
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="scanResults" style="max-height: 400px; overflow-y: auto;">
                        <div class="empty-state">
                            <i class="bi bi-hourglass-split"></i>
                            <p>Escaneando redes (esto puede tomar 10-20 segundos)...</p>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle"></i>
                        Cerrar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <!-- Bootstrap JS -->
    <script src="/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // ===== SISTEMA DE TOASTS =====
        function showToast(title, message, type = 'info') {
            const toastId = 'toast-' + Date.now();
            const icons = {
                'success': 'bi-check-circle',
                'error': 'bi-exclamation-circle',
                'warning': 'bi-exclamation-triangle',
                'info': 'bi-info-circle'
            };
            
            const toast = document.createElement('div');
            toast.id = toastId;
            toast.className = `toast ${type}`;
            toast.setAttribute('role', 'alert');
            toast.setAttribute('aria-live', 'assertive');
            toast.setAttribute('aria-atomic', 'true');
            
            toast.innerHTML = `
                <div class="toast-header">
                    <i class="bi ${icons[type]} toast-icon"></i>
                    <strong class="me-auto">${title}</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" style="filter: invert(1);"></button>
                </div>
                <div class="toast-body">
                    ${message}
                </div>
            `;
            
            const container = document.getElementById('toastContainer');
            container.appendChild(toast);
            
            const bsToast = new bootstrap.Toast(toast);
            bsToast.show();
            
            // Remover el elemento después de que se oculte
            toast.addEventListener('hidden.bs.toast', () => {
                toast.remove();
            });
            
            return bsToast;
        }

        // ===== WEBSOCKET =====
        let ws;
        let cards = [];
        let config = {};
        let scanTimeoutId = null;

        function connectWebSocket() {
            ws = new WebSocket('ws://' + window.location.hostname + '/ws');
            
            ws.onopen = function() {
                console.log('WebSocket conectado');
                updateSocketStatus(true);
                refreshConfig();
            };
            
            ws.onclose = function() {
                console.log('WebSocket desconectado');
                updateSocketStatus(false);
                setTimeout(connectWebSocket, 3000);
            };
            
            ws.onerror = function(error) {
                console.error('Error WebSocket:', error);
                updateSocketStatus(false);
            };
            
            ws.onmessage = function(event) {
                try {
                    const data = JSON.parse(event.data);
                    handleMessage(data);
                } catch(e) {
                    console.log('Mensaje recibido:', event.data);
                }
            };
        }

        function updateSocketStatus(connected) {
            const status = document.getElementById('socketStatus');
            if (connected) {
                status.className = 'socket-status connected';
                status.innerHTML = '<i class="bi bi-circle-fill"></i><span class="d-none d-sm-inline">Conectado</span>';
            } else {
                status.className = 'socket-status disconnected';
                status.innerHTML = '<i class="bi bi-circle-fill"></i><span class="d-none d-sm-inline">Desconectado</span>';
            }
        }

        function sendCommand(command, params = {}) {
            if(ws && ws.readyState === WebSocket.OPEN) {
                const msg = {command: command, ...params};
                ws.send(JSON.stringify(msg));
            } else {
                showToast('Error', 'WebSocket no está conectado', 'error');
            }
        }

        function handleMessage(data) {
            if(data.type === 'card') {
                addCard(data.uid, data.timestamp);
            } 
            else if(data.type === 'system_info' || data.type === 'config') {
                updateSystemInfo(data);
            }
            else if(data.type === 'success') {
                console.log('Respuesta exitosa:', data.message);
                showToast('Éxito', data.message, 'success');
                
                // Si es un cambio de modo con reinicio, avisar al usuario
                if(data.reboot) {
                    showToast('Reiniciando', 'El dispositivo se reiniciará en 3 segundos...', 'warning');
                }
                
                refreshConfig();
            }
            else if(data.type === 'info') {
                console.log('Info:', data.message);
                showToast('Información', data.message, 'info');
            }
            else if(data.type === 'scan_started') {
                console.log('Escaneo iniciado');
                document.getElementById('scanResults').innerHTML = `
                    <div class="empty-state">
                        <i class="bi bi-hourglass-split" style="animation: spin 1s linear infinite;"></i>
                        <p>Escaneando redes WiFi...</p>
                        <small class="text-muted">Esto puede tomar 10-20 segundos</small>
                    </div>
                `;
            }
            else if(data.type === 'scan_result') {
                showScanResults(data.networks);
            }
            else if(data.type === 'wifi_connected') {
                showToast('Conexión WiFi', `Conectado a: ${data.ssid}\nIP: ${data.ip}`, 'success');
                refreshConfig();
            }
            else if(data.type === 'wifi_disconnected') {
                showToast('WiFi', 'Conexión WiFi perdida', 'warning');
                refreshConfig();
            }
            else if(data.type === 'error') {
                if(data.message && data.message.includes('escanear')) {
                    console.warn('Error de escaneo:', data.message);
                } else {
                    showToast('Error', data.message, 'error');
                }
            }
        }

        function updateSystemInfo(data) {
            config = data;
            
            document.getElementById('sensorId').textContent = data.sensor_id || '-';
            document.getElementById('firmware').textContent = data.firmware_version || '-';
            document.getElementById('apIP').textContent = data.ap_ip || '-';
            
            // Actualizar modo actual
            if(data.current_mode) {
                const modeBadge = document.getElementById('modeBadge');
                const modeSelect = document.getElementById('modeSelect');
                
                // Guardar el modo actual globalmente para comparación
                window.currentMode = data.current_mode;
                
                if(data.current_mode === 'standalone') {
                    modeBadge.innerHTML = '<i class="bi bi-circle-fill"></i> Standalone';
                    modeBadge.className = 'status-badge connected';
                    modeSelect.value = 'standalone';
                } else if(data.current_mode === 'turnstile') {
                    modeBadge.innerHTML = '<i class="bi bi-circle-fill"></i> Torniquete';
                    modeBadge.className = 'status-badge' ;
                    modeBadge.style.backgroundColor = 'rgba(245, 158, 11, 0.2)';
                    modeBadge.style.color = 'var(--warning)';
                    modeBadge.style.borderColor = 'var(--warning)';
                    modeSelect.value = 'turnstile';
                }
                
                // Mostrar/ocultar panel de control de torniquete
                const turnstileRow = document.getElementById('turnstileControlRow');
                if(data.current_mode === 'turnstile') {
                    turnstileRow.style.display = '';
                } else {
                    turnstileRow.style.display = 'none';
                }
                
                // Actualizar estado del botón
                updateChangeModeButton();
            }
            
            const wifiStatus = document.getElementById('wifiStatus');
            if(data.wifi_connected) {
                wifiStatus.innerHTML = `
                    <span class="status-badge connected">
                        <i class="bi bi-circle-fill"></i>
                        Conectado
                    </span>
                `;
                document.getElementById('wifiSSIDRow').style.display = 'flex';
                document.getElementById('wifiIPRow').style.display = 'flex';
                document.getElementById('wifiSSID').textContent = data.wifi_ssid || '-';
                document.getElementById('wifiIP').textContent = data.wifi_ip || '-';
            } else {
                wifiStatus.innerHTML = `
                    <span class="status-badge disconnected">
                        <i class="bi bi-circle-fill"></i>
                        Desconectado
                    </span>
                `;
                document.getElementById('wifiSSIDRow').style.display = 'none';
                document.getElementById('wifiIPRow').style.display = 'none';
            }
            
            if(data.known_networks) {
                renderKnownNetworks(data.known_networks);
            }
        }

        function renderKnownNetworks(networks) {
            const list = document.getElementById('knownNetworksList');
            
            if(networks.length === 0) {
                list.innerHTML = `
                    <div class="empty-state">
                        <i class="bi bi-diagram-3"></i>
                        <p>No hay redes configuradas</p>
                    </div>
                `;
                return;
            }
            
            list.innerHTML = '';
            networks.forEach(net => {
                const item = document.createElement('div');
                item.className = 'network-item';
                
                const info = document.createElement('div');
                info.className = 'network-info';
                
                const ssid = document.createElement('div');
                ssid.className = 'network-ssid';
                ssid.textContent = net.ssid;
                
                const ssidWithIcon = document.createElement('div');
                ssidWithIcon.className = 'network-ssid';
                ssidWithIcon.innerHTML = `<i class="bi bi-wifi"></i>${net.ssid}`;
                
                const meta = document.createElement('div');
                meta.className = 'network-meta';
                meta.innerHTML = net.has_password ? '<i class="bi bi-lock-fill"></i> Protegida' : '<i class="bi bi-unlock-fill"></i> Abierta';
                
                info.innerHTML = '';
                
                info.appendChild(ssid);
                info.appendChild(meta);
                
                const btn = document.createElement('button');
                btn.className = 'btn btn-sm btn-danger';
                btn.innerHTML = '<i class="bi bi-trash"></i>';
                btn.onclick = () => deleteWiFi(net.ssid);
                
                item.appendChild(info);
                item.appendChild(btn);
                list.appendChild(item);
            });
        }

        function refreshConfig() {
            sendCommand('getConfig');
        }

        function showAddWiFiModal() {
            new bootstrap.Modal(document.getElementById('addWiFiModal')).show();
        }

        function addWiFi() {
            const ssid = document.getElementById('newSSID').value.trim();
            const password = document.getElementById('newPassword').value;
            
            if(!ssid) {
                showToast('Validación', 'Debes ingresar un SSID', 'warning');
                return;
            }
            
            if(ssid.length > 32) {
                showToast('Validación', 'El SSID no puede exceder 32 caracteres', 'warning');
                return;
            }
            
            if(password.length > 63) {
                showToast('Validación', 'La contraseña no puede exceder 63 caracteres', 'warning');
                return;
            }
            
            sendCommand('addWiFi', {ssid: ssid, password: password});
            
            document.getElementById('newSSID').value = '';
            document.getElementById('newPassword').value = '';
            bootstrap.Modal.getInstance(document.getElementById('addWiFiModal')).hide();
        }

        function deleteWiFi(ssid) {
            if(confirm(`¿Eliminar la red "${ssid}"?`)) {
                sendCommand('deleteWiFi', {ssid: ssid});
            }
        }

        function scanNetworks() {
            const modal = new bootstrap.Modal(document.getElementById('scanModal'));
            modal.show();
            
            document.getElementById('scanResults').innerHTML = `
                <div class="empty-state">
                    <i class="bi bi-hourglass-split" style="animation: spin 1s linear infinite;"></i>
                    <p>Escaneando redes WiFi...</p>
                    <small class="text-muted">Esto puede tomar 10-20 segundos</small>
                </div>
            `;
            
            // Mostrar advertencia después de 25 segundos
            scanTimeoutId = setTimeout(() => {
                const results = document.getElementById('scanResults');
                if(results.innerHTML.includes('Escaneando')) {
                    results.innerHTML = `
                        <div class="empty-state">
                            <i class="bi bi-exclamation-triangle"></i>
                            <p>El escaneo está tomando mucho tiempo</p>
                            <small class="text-muted">Intente cerrar y escanear nuevamente</small>
                        </div>
                    `;
                }
            }, 25000);
            
            sendCommand('scanNetworks');
        }

        function showScanResults(networks) {
            if(scanTimeoutId) {
                clearTimeout(scanTimeoutId);
            }
            
            const list = document.getElementById('scanResults');
            
            if(networks.length === 0) {
                list.innerHTML = `
                    <div class="empty-state">
                        <i class="bi bi-wifi-off"></i>
                        <p>No se encontraron redes WiFi</p>
                    </div>
                `;
                return;
            }
            
            list.innerHTML = '';
            networks.forEach(net => {
                const item = document.createElement('div');
                item.className = 'network-item';
                
                const info = document.createElement('div');
                info.className = 'network-info';
                
                const ssidEl = document.createElement('div');
                ssidEl.className = 'network-ssid';
                let signalIcon = 'bi-wifi-1';
                if(net.rssi > -60) signalIcon = 'bi-wifi';
                else if(net.rssi > -70) signalIcon = 'bi-wifi-2';
                ssidEl.innerHTML = `<i class="bi ${signalIcon}"></i>${net.ssid}`;
                
                const meta = document.createElement('div');
                meta.className = 'network-meta';
                const lockIcon = net.encryption !== 'Open' ? '<i class="bi bi-lock-fill"></i>' : '<i class="bi bi-unlock-fill"></i>';
                meta.innerHTML = `${lockIcon} ${net.encryption} <span style="margin-left: 0.5rem;">Señal: ${net.rssi} dBm</span>`;
                
                info.appendChild(ssidEl);
                info.appendChild(meta);
                
                const btn = document.createElement('button');
                btn.className = 'btn btn-sm btn-success';
                btn.innerHTML = '<i class="bi bi-plus-circle-fill"></i>';
                btn.onclick = () => quickAddWiFi(net.ssid);
                
                item.appendChild(info);
                item.appendChild(btn);
                list.appendChild(item);
            });
        }

        function quickAddWiFi(ssid) {
            bootstrap.Modal.getInstance(document.getElementById('scanModal')).hide();
            document.getElementById('newSSID').value = ssid;
            showAddWiFiModal();
        }

        function connectWiFi() {
            sendCommand('connectWiFi');
            showToast('Conexión WiFi', 'Intentando conectar a red conocida...', 'info');
        }

        function addCard(uid, timestamp) {
            const cardItem = {
                uid: uid,
                time: new Date().toLocaleTimeString(),
                timestamp: timestamp
            };
            
            cards.unshift(cardItem);
            if(cards.length > 50) cards.pop();
            
            renderCards();
        }

        function renderCards() {
            const cardList = document.getElementById('cardList');
            
            if(cards.length === 0) {
                cardList.innerHTML = `
                    <div class="empty-state">
                        <i class="bi bi-inbox"></i>
                        <p>Esperando tarjetas...</p>
                    </div>
                `;
                return;
            }
            
            cardList.innerHTML = '';
            cards.forEach(card => {
                const item = document.createElement('div');
                item.className = 'card-item';
                
                const uid = document.createElement('div');
                uid.className = 'card-uid';
                uid.textContent = card.uid;
                
                const time = document.createElement('div');
                time.className = 'card-time';
                time.innerHTML = `<i class="bi bi-clock"></i> ${card.time}`;
                
                item.appendChild(uid);
                item.appendChild(time);
                cardList.appendChild(item);
            });
        }

        function clearHistory() {
            if(confirm('¿Limpiar todo el historial de tarjetas?')) {
                cards = [];
                renderCards();
                showToast('Historial', 'Historial limpiado correctamente', 'success');
            }
        }

        function changeMode() {
            const mode = document.getElementById('modeSelect').value;
            
            if(!mode) {
                showToast('Validación', 'Selecciona un modo', 'warning');
                return;
            }
            
            // Verificar si es el mismo modo
            if(window.currentMode && mode === window.currentMode) {
                showToast('Información', 'Ya estás en modo ' + (mode === 'standalone' ? 'Standalone' : 'Torniquete'), 'info');
                return;
            }
            
            const modeNames = {
                'standalone': 'Standalone',
                'turnstile': 'Torniquete'
            };
            
            if(confirm(`¿Cambiar al modo ${modeNames[mode]}?\n\nEl dispositivo se reiniciará para aplicar los cambios.`)) {
                sendCommand('setMode', {mode: mode});
                showToast('Modo de Operación', `Cambiando a modo ${modeNames[mode]}...`, 'info');
                
                // Mostrar mensaje de reinicio después de 2 segundos
                setTimeout(() => {
                    showToast('Reiniciando', 'El dispositivo se está reiniciando. Reconectando en 10 segundos...', 'warning');
                }, 2000);
            }
        }
        
        function updateChangeModeButton() {
            const modeSelect = document.getElementById('modeSelect');
            const changeBtn = document.querySelector('button[onclick="changeMode()"]');
            
            if(!changeBtn || !modeSelect) return;
            
            // Añadir listener al select para actualizar el botón cuando cambia
            modeSelect.addEventListener('change', function() {
                if(window.currentMode && this.value === window.currentMode) {
                    changeBtn.disabled = true;
                    changeBtn.style.opacity = '0.5';
                    changeBtn.innerHTML = '<i class="bi bi-check-circle"></i> Modo Actual';
                } else {
                    changeBtn.disabled = false;
                    changeBtn.style.opacity = '1';
                    changeBtn.innerHTML = '<i class="bi bi-gear-fill"></i> Cambiar Modo';
                }
            });
            
            // Disparar el evento change para inicializar el estado
            modeSelect.dispatchEvent(new Event('change'));
        }

        // Funciones de control del torniquete
        function unlockTurnstile() {
            if(confirm('¿Desbloquear el torniquete?\n\nSe bloqueará automáticamente después de 5 segundos.')) {
                sendCommand('unlockTurnstile', {});
                showToast('Torniquete', 'Desbloqueando...', 'info');
            }
        }

        function lockTurnstile() {
            if(confirm('¿Bloquear el torniquete manualmente?')) {
                sendCommand('lockTurnstile', {});
                showToast('Torniquete', 'Bloqueando...', 'info');
            }
        }

        // Conectar al cargar la página
        connectWebSocket();
    </script>
</body>
</html>
